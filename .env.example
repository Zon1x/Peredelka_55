# Скопируйте в .env и подставьте свои значения.

# Django
SECRET_KEY=your_actual_django_secret_key_here
DJANGO_DEBUG=True
SITE_NAME=Peredelka55
# Версия для ?v= у CSS/JS (сброс кэша). Скрипт scripts/run-dev.ps1 задаёт время автоматически.
ASSET_VERSION=5
ALLOWED_HOSTS=localhost,127.0.0.1,your_domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your_domain.com

# БД: не задавайте DATABASE_URL — будет SQLite (удобно локально).
# Docker Compose сам подставит DATABASE_URL в сервисе web (см. docker-compose.yml).
# Для продакшена на VPS укажите строку подключения к PostgreSQL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

POSTGRES_DB=peredelka55_db
POSTGRES_USER=peredelka55_user
POSTGRES_PASSWORD=peredelka55_password

# Пример строки из контейнера web к сервису db (если настраиваете вручную):
# DATABASE_URL=postgresql://peredelka55_user:peredelka55_password@db:5432/peredelka55_db

# Redis: локально без Docker
REDIS_URL=redis://127.0.0.1:6379/1
# Внутри Docker Compose для web переопределяется на redis://redis:6379/1

# Почта
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=your_email@gmail.com
ADMIN_EMAIL=admin@your_domain.com

# Логи в файл logs/django.log (false — только консоль, удобно в Docker)
DJANGO_USE_FILE_LOG=true

# WhiteNoise: true — CompressedManifestStaticFilesStorage (кэш-бастинг, строгий collectstatic)
DJANGO_WHITENOISE_MANIFEST=false

# Безопасность (после HTTPS)
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
